{
  "_instructions": [
    "For each osc type, for each of the three knobs (the slots are keyed 'wave'/'timbre'/'shape' but the MicroFreak often displays a different NAME per osc type — capture it in the 'name' field).",
    "",
    "Each parameter has three fields:",
    "  name   — the label the MicroFreak screen shows for this knob under this osc type (e.g. 'Sym', 'Fold', 'Detune').",
    "  range  — [min, max] or [min, max, \"unit\"] for continuous (numeric) parameters.",
    "  values — array of strings for DISCRETE parameters (e.g. [\"Sine\",\"Tri\",\"Saw\",\"Sqr\",\"Pulse\"]).",
    "  Fill ONE of 'range' OR 'values'. If you fill both, 'values' wins.",
    "",
    "Leave defaults (name = 'Wave'/'Timbre'/'Shape', range = [0,100]) where you're unsure — we'll refine iteratively.",
    "You don't have to fill all 22 osc types at once; unfilled ones fall back to generic 0-100.",
    "Keep the outer keys (osc type names) EXACTLY as written — they match the _osc_type() labels in src/model/index.js."
  ],
  "ranges": {
    "Basic Waves":     { "wave": { "name": "Morph",   "range": [0, 100] }, "timbre": { "name": "Sym", "range": [50, 95] }, "shape": { "name": "Sub", "range": [0, 100] } },
    "Superwave":       { "wave": { "name": "Wave-Type",   "range": [0, 100] }, "timbre": { "name": "DeTune", "range": [0, 100] }, "shape": { "name": "Volume", "range": [0, 100] } },
    "Wavetable":       { "wave": { "name": "Table",   "range": [0, 10] }, "timbre": { "name": "Position", "range": [0, 100] }, "shape": { "name": "Chorus", "range": [0, 100] } },
    "Harmo":           { "wave": { "name": "Content",   "range": [0, 100] }, "timbre": { "name": "Sculpting", "range": [0, 100] }, "shape": { "name": "Chorus", "range": [0, 100] } },
    "Karplus Strong":  { "wave": { "name": "Bow",   "range": [0, 100] }, "timbre": { "name": "Position", "range": [0, 100] }, "shape": { "name": "Decay", "range": [0, 100] } },
    "V. Analog":       { "wave": { "name": "DeTune",   "range": [0, 100] }, "timbre": { "name": "Shape", "range": [0, 100] }, "shape": { "name": "Wave", "range": [0, 100] } },
